# === Database ===
# For local development (SQLite):
DATABASE_URL="file:./dev.db"
# For production on Vercel (Turso - SQLite compatible, free):
# Install: npm install -g turso
# Create: turso db create fm-beauty
# Get URL + token: turso db show fm-beauty --url && turso db tokens create fm-beauty
# DATABASE_URL="libsql://fm-beauty-<org>.turso.io?authToken=<token>"

# === NextAuth ===
NEXTAUTH_SECRET="change-this-to-a-random-string"
NEXTAUTH_URL="http://localhost:3000"
# For production:
# NEXTAUTH_URL="https://yourdomain.com"
